# ================================
# SentinelQuant Environment Config
# ================================

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sentinelquant

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# API Keys - News Sources
NEWS_API_KEY=your_newsapi_key_here

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SentinelQuant/1.0

# FinBERT API (Hugging Face)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx

# Scraping Configuration
SCRAPE_INTERVAL_MINUTES=15
MAX_ARTICLES_PER_SOURCE=50

# Portfolio Configuration
DEFAULT_PORTFOLIO_SIZE=10000
MAX_POSITION_PERCENT=25
REBALANCE_THRESHOLD=0.05
QUOTE_PROVIDER=twelvedata
QUOTE_API_KEY=your_quote_api_key_here
QUOTE_API_BASE_URL=https://api.twelvedata.com
QUOTE_CACHE_MINUTES=5
NSE_INSTRUMENTS_URL=https://archives.nseindia.com/content/equities/EQUITY_L.csv

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
